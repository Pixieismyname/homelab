########################################
# MÍMIR'S WELL
# Single source of truth for Skirnir
########################################

########################################
# Host Identity
########################################

HOSTNAME=skirnir
DOMAIN=aegirshus

########################################
# Locale / Time
########################################

TZ=Europe/Stockholm

########################################
# User IDs (Linux permissions)
########################################

PUID=1000
PGID=1000

########################################
# Root Data Paths
########################################

DATA_ROOT=/srv
DOCKER_DATA=/srv/docker

########################################
# Shared Storage
########################################

MEDIA_PATH=/srv/media
DOWNLOADS_PATH=/srv/downloads

########################################
# Application Storage
########################################

PAPERLESS_PATH=/srv/paperless
WAZUH_PATH=/srv/wazuh

########################################
# Docker Networking
########################################

PROXY_NETWORK=proxy

########################################
# Service Hostnames
########################################

JELLYFIN_HOST=jellyfin.${DOMAIN}
PAPERLESS_HOST=paperless.${DOMAIN}
HOMEASSISTANT_HOST=ha.${DOMAIN}
WAZUH_HOST=wazuh.${DOMAIN}