{
	# Global options
	# Email is only needed if you later enable public ACME certs.
	# email you@example.com

	# Helpful during early bring-up
	log {
		level INFO
	}
}

# DNS (AdGuard Home UI)
http://{$DNS_HOST} {
	reverse_proxy adguard:3000
}

# Optional landing page
http://proxy.{$DOMAIN} {
	respond "Caddy is running on skirnir" 200
}

# Jellyfin
http://{$JELLYFIN_HOST} {
	reverse_proxy jellyfin:8096
}

# Paperless-ngx
http://{$PAPERLESS_HOST} {
	reverse_proxy paperless:8000
}

# Home Assistant (host network)
http://{$HOMEASSISTANT_HOST} {
	# On Linux, Caddy runs in Docker; it needs to reach the host's port 8123.
	# host.docker.internal is supported on modern Docker; we'll add a fallback later if needed.
	reverse_proxy host.docker.internal:8123
}

# Wazuh Dashboard
http://{$WAZUH_HOST} {
	reverse_proxy wazuh-dashboard:5601
}