{
	# Global options
	# Email is only needed if you later enable public ACME certs.
	# email you@example.com

	# Helpful during early bring-up
	log {
		level INFO
	}
}

# DNS (AdGuard Home UI)
http://{$DNS_HOST} {
	reverse_proxy adguard:3000
}

# Optional landing page
http://proxy.{$DOMAIN} {
	respond "Caddy is running on skirnir" 200
}

# Homepage
http://{$HOMEPAGE_HOST} {
	reverse_proxy homepage:3000
}

# Portainer
http://{$PORTAINER_HOST} {
	reverse_proxy portainer:9000
}

# Jellyfin
http://{$JELLYFIN_HOST} {
	reverse_proxy jellyfin:8096
}

# Paperless-ngx
http://{$PAPERLESS_HOST} {
	reverse_proxy paperless:8000
}

# Home Assistant (host network)
http://{$HOMEASSISTANT_HOST} {
	# On Linux, Caddy runs in Docker; it needs to reach the host's port 8123.
	# host.docker.internal is supported on modern Docker; we'll add a fallback later if needed.
	reverse_proxy host.docker.internal:8123
}

# Wazuh Dashboard
http://{$WAZUH_HOST} {
	reverse_proxy wazuh-dashboard:5601
}

# Prowlarr
http://{$PROWLARR_HOST} {
	reverse_proxy prowlarr:9696
}

# Sonarr
http://{$SONARR_HOST} {
	reverse_proxy sonarr:8989
}

# Radarr
http://{$RADARR_HOST} {
	reverse_proxy radarr:7878
}

# Bazarr
http://{$BAZARR_HOST} {
	reverse_proxy bazarr:6767
}

# qBittorrent
http://{$QBITTORRENT_HOST} {
	reverse_proxy qbittorrent:8080
}