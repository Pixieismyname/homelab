########################################
# Paperless-ngx stack-specific config
# Copy to: paperless.env   (do not commit once server is live)
########################################

# Required: set a long random string (keep secret)
PAPERLESS_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Optional but recommended when behind a reverse proxy:
# This helps Paperless generate correct absolute URLs in some situations.
PAPERLESS_URL=http://paperless.aegirshus

# Admin / first user experience:
# If you leave these blank, Paperless will prompt you to create a superuser on first access.
# PAPERLESS_ADMIN_USER=admin
# PAPERLESS_ADMIN_PASSWORD=change-me
# PAPERLESS_ADMIN_MAIL=admin@aegirshus

# OCR language(s) – add what you need (example: English + Swedish)
# PAPERLESS_OCR_LANGUAGE=eng+sv

# DB credentials are sourced from shared env (.env from mimir.env.example):
# PAPERLESS_DBNAME
# PAPERLESS_DBUSER
# PAPERLESS_DBPASS